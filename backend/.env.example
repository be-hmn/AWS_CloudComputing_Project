NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=10

# 시드 ADMIN 계정 (서버 기동 시 자동 생성)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin1234
SEED_ADMIN_NAME=Administrator

# S3 (값을 비워두면 파일 업로드/다운로드 URL은 mock으로 동작)
AWS_REGION=ap-northeast-2
S3_BUCKET=
S3_PRESIGN_TTL_SECONDS=300

# 파일 업로드 정책
FILE_MAX_BYTES=10485760
FILE_ALLOWED_MIME=image/png,image/jpeg,image/webp,application/pdf

LOG_LEVEL=info

# CORS — 허용 origin (쉼표 구분, * 는 전체 허용)
# 개발: * (기본값)
# EC2 배포: http://<프론트_EC2_IP> 또는 S3 정적 호스팅 URL
CORS_ORIGIN=*

# ────────────────────────────────────────────────────────
# V2 (RDS/MySQL 연결) 준비용 환경 변수.
# V1 인메모리 모드에서는 사용하지 않으며, npm run migrate 실행 시에만 필요.
# ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mentoring
DB_POOL_LIMIT=10

